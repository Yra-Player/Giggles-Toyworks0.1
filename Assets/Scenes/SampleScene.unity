--- !u!102 &561790691
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 561790689}
  m_Text: "\u0421\u043F\u044F\u0449\u0430\u044F \u043A\u0440\u0430\u0441\u0430\u0432\u0438\u0446\u0430
    \u0432 \u0437\u0430\u0442\u043E\u0447\u0435\u043D\u0438\u0438\r\n\u041A\u0430\u043A
    \u0438 \u041F\u043E\u043F\u043F\u0438, \u0438\u0433\u0440\u043E\u043A \u043D\u0430\u0445\u043E\u0434\u0438\u0442
    \u0412\u0435\u0441\u043F\u0435\u0440\n \u0432 \u0441\u0430\u043C\u043E\u043C
    \u043A\u043E\u043D\u0446\u0435 \u043F\u0435\u0440\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u044B.\n\u041E\u043D\u0430
    \u0437\u0430\u043F\u0435\u0440\u0442\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0432 \u043A\u043E\u0440\u043E\u0431\u043A\u0435,\n \u0430 \u0432 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u043E\u0439 \u0431\u0430\u0440\u043E\u043A\u0430\u043C\u0435\u0440\u0435
    \u0432 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0433\u043E
    \u0446\u0435\u0445\u0430\xBB ).\r\n\u041A\u043E\u0433\u0434\u0430 \u0438\u0433\u0440\u043E\u043A
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u043A\u0430\u043C\u0435\u0440\u0443,
    \u0412\u0435\u0441\u043F\u0435\u0440 \u043D\u0435 \u043D\u0430\u043F\u0430\u0434\u0430\u0435\u0442.\n\u041E\u043D\u0430
    \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0437\u0430 \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u0441\u0432\u043E\u0438\u043C\n \xAB\u0448\u0435\u043F\u0447\u0443\u0449\u0438\u043C\xBB
    \u0433\u043E\u043B\u043E\u0441\u043E\u043C: \xAB\u0442\u044B \u043F\u0440\u0438\u0448\u0435\u043B
    \u0437\u0430 \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u043C\u0438? (\u043F\u0430\u0443\u0437\u0430
    1-3 \u0441\u0435\u043A\u0443\u043D\u0434\u044B)  \u042F \u0436\u0434\u0430\u043B\u0430
    \u0442\u0435\u0431\u044F \u043E\u0447\u0435\u043D\u044C \u0434\u043E\u043B\u0433\u043E.\xBB."
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
