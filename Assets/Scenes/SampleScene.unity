--- !u!102 &1891212187
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1891212185}
  m_Text: "\u0418\u0434\u0435\u044F \u0437\u0430\u043C\u0435\u043D\u044B Poppy\n\u043A\u0443\u043A\u043B\u0430
    \u0412\u0435\u0441\u043F\u0435\u0440\n\u0412\u043D\u0435\u0448\u043D\u0438\u0439
    \u0432\u0438\u0434:\r\n\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B: \u041E\u043D\u0430
    \u043D\u0435 \u0438\u0437 \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E \u043F\u043B\u0430\u0441\u0442\u0438\u043A\u0430,
    \u0430 \u043E\u0431\u0442\u044F\u043D\u0443\u0442\u0430 \u0442\u043E\u043D\u0447\u0430\u0439\u0448\u0435\u0439,
    \u043F\u043E\u0447\u0442\u0438 \xAB\u043A\u043E\u0436\u043D\u043E\u0439\xBB \u0431\u043B\u0435\u0434\u043D\u043E\u0439
    \u0437\u0430\u043C\u0448\u0435\u0439. \u041D\u0430 \u043E\u0449\u0443\u043F\u044C
    \u043E\u043D\u0430 \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u0442\u0451\u043F\u043B\u043E\u0439,
    \u0447\u0442\u043E \u043F\u0443\u0433\u0430\u0435\u0442 \u0434\u0435\u0442\u0435\u0439.\r\n\u041B\u0438\u0446\u043E:
    \u0412\u043C\u0435\u0441\u0442\u043E \u0440\u0438\u0441\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0443\u043B\u044B\u0431\u043A\u0438 \u0443 \u043D\u0435\u0451 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0433\u043B\u0430\u0434\u043A\u043E\u0435 \u043B\u0438\u0446\u043E, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0432\u044B\u0448\u0438\u0442\u044B
    \u0447\u0435\u0440\u0442\u044B. \u0413\u043B\u0430\u0437\u0430 \u2014 \u043A\u0440\u0443\u043F\u043D\u044B\u0435
    \u043F\u0443\u0433\u043E\u0432\u0438\u0446\u044B \u0438\u0437 \u0447\u0451\u0440\u043D\u043E\u0433\u043E
    \u043E\u043D\u0438\u043A\u0441\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0431\u043B\u0435\u0441\u0442\u044F\u0442, \u043A\u0430\u043A \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0435
    \u0437\u0440\u0430\u0447\u043A\u0438.\r\n\u0412\u043E\u043B\u043E\u0441\u044B:
    \u0414\u043B\u0438\u043D\u043D\u044B\u0435, \u043F\u0440\u044F\u043C\u044B\u0435
    \u0432\u043E\u043B\u043E\u0441\u044B \u0446\u0432\u0435\u0442\u0430 \xAB\u043D\u043E\u0447\u043D\u043E\u0433\u043E
    \u0438\u043D\u0434\u0438\u0433\u043E\xBB (\u0442\u0435\u043C\u043D\u043E-\u0441\u0438\u043D\u0438\u0435),
    \u0443\u043A\u0440\u0430\u0448\u0435\u043D\u043D\u044B\u0435 \u0437\u0430\u043A\u043E\u043B\u043A\u0430\u043C\u0438
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u0445
    \u043C\u043E\u0442\u044B\u043B\u044C\u043A\u043E\u0432.\r\n\u041E\u0434\u0435\u0436\u0434\u0430:
    \u0422\u0451\u043C\u043D\u043E-\u0441\u0438\u043D\u0435\u0435 \u0431\u0430\u0440\u0445\u0430\u0442\u043D\u043E\u0435
    \u043F\u043B\u0430\u0442\u044C\u0435 \u0441 \u043F\u044B\u0448\u043D\u044B\u043C\u0438
    \u0440\u0443\u043A\u0430\u0432\u0430\u043C\u0438-\u0444\u043E\u043D\u0430\u0440\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0432\u043E\u0440\u043E\u0442\u043D\u0438\u043A\u043E\u043C \u0438\u0437
    \u0431\u0435\u043B\u044B\u0445 \u043F\u0435\u0440\u044C\u0435\u0432. \u041D\u0430
    \u0433\u0440\u0443\u0434\u0438 \u2014 \u0431\u0440\u043E\u0448\u044C \u0432 \u0432\u0438\u0434\u0435
    \u0437\u0430\u043C\u043E\u0447\u043D\u043E\u0439 \u0441\u043A\u0432\u0430\u0436\u0438\u043D\u044B.\n"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
