--- !u!102 &19569229
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 19569227}
  m_Text: "\u041A\u043E\u043D\u0446\u0435\u043F\u0442 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0430\u043D\u0442\u0430\u0433\u043E\u043D\u0438\u0441\u0442\u0430\n\u0418\u043C\u044F:
    \u041C\u0435\u0439\u043D-\u041C\u044D\u0439\u0445\u0435\u043C (Maine Mayhem)
    \u0438\u043C\u044F \u0432 \u043A\u0430\u0442\u0430\u043B\u043E\u0433\u0435 \u0438\u0433\u0440\u0443\u0448\u0435\u043A:
    \xAB\u041C\u0443\u0440\u043B\u044B\u043A\u0430 \u041C\u0435\u0439\u043D\xBB.\n\u0414\u0438\u0437\u0430\u0439\u043D
    (\u0418\u0433\u0440\u0443\u0448\u043A\u0430)\r\n\u0413\u0430\u0431\u0430\u0440\u0438\u0442\u044B:
    \u042D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u043E\u0442,
    \u044D\u0442\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u0430\u044F, \u0432\u044B\u0442\u044F\u043D\u0443\u0442\u0430\u044F
    \u0438\u0433\u0440\u0443\u0448\u043A\u0430 \u0434\u043B\u0438\u043D\u043E\u0439
    \u043E\u043A\u043E\u043B\u043E 3 \u043C\u0435\u0442\u0440\u043E\u0432 (\u0435\u0441\u043B\u0438
    \u0440\u0430\u0441\u0442\u044F\u043D\u0443\u0442\u044C). \u0423 \u043D\u0435\u0433\u043E
    \u043D\u0435\u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E
    \u0434\u043B\u0438\u043D\u043D\u044B\u0435, \u0433\u0438\u0431\u043A\u0438\u0435
    \u043B\u0430\u043F\u044B, \u043A\u0430\u043A \u0443 Huggy Wuggy, \u043D\u043E
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u0435\u0435.\r\n\u0428\u0435\u0440\u0441\u0442\u044C:
    \u0420\u0430\u043D\u044C\u0448\u0435 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0440\u043E\u0441\u043A\u043E\u0448\u043D\u043E\u0439, \u0440\u044B\u0436\u0435-\u0437\u043E\u043B\u043E\u0442\u0438\u0441\u0442\u043E\u0439.\r\n\u0413\u043E\u043B\u043E\u0432\u0430
    \u0438 \u043B\u0438\u0446\u043E:\r\n\u0423 \u043D\u0435\u0433\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C
    \u0444\u0438\u0440\u043C\u0435\u043D\u043D\u044B\u0435 \u043A\u0438\u0441\u0442\u043E\u0447\u043A\u0438
    \u043D\u0430 \u0443\u0448\u0430\u0445, \u043D\u043E \u0442\u0435\u043F\u0435\u0440\u044C
    \u043E\u043D\u0438 \u0432\u044B\u0433\u043B\u044F\u0434\u044F\u0442 \u043A\u0430\u043A
    \u043E\u0441\u0442\u0440\u044B\u0435 \u0430\u043D\u0442\u0435\u043D\u043D\u044B
    \u0438\u043B\u0438 \u0448\u0438\u043F\u044B.\r\n\u0413\u043B\u0430\u0437\u0430:
    \u041E\u0433\u0440\u043E\u043C\u043D\u044B\u0435, \u0436\u0435\u043B\u0442\u044B\u0435,
    \u0441 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C
    \u0437\u0440\u0430\u0447\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0432\u0435\u0442\u0438\u0442\u0441\u044F \u0432 \u0442\u0435\u043C\u043D\u043E\u0442\u0435
    (\u0441\u0432\u0435\u0442\u043E\u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0449\u0430\u044F
    \u0442\u043A\u0430\u043D\u044C).\r\n\u041C\u043E\u0440\u0434\u0430:  \u043C\u0438\u043B\u0430\u044F
    \u043A\u043E\u0448\u0430\u0447\u044C\u044F \u043C\u043E\u0440\u0434\u0430 \n\n"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
  m_RichText: 1
  m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
  m_Color:
    serializedVersion: 2
    rgba: 4278190080
