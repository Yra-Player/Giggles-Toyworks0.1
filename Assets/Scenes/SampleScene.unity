--- !u!102 &742372724
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 742372722}
  m_Text: "\u0412\u043E\u0437\u043C\u0430\u0436\u043D\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F
    \u0441\u044E\u0436\u0435\u0442\u0430\n\u0413\u043B\u0430\u0432\u0430 1:  \"\u0422\u0438\u0445\u0438\u0439
    \u0448\u0451\u043F\u043E\u0442\"\n\u0422\u044B \u0431\u044B\u0432\u0448\u0438\u0439
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A \u043E\u0442\u0434\u0435\u043B\u0430
    \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438\n\u041F\u043E\u043B\u0443\u0447\u0430\u0435\u0448\u044C
    \u2014 \u0441\u0442\u0430\u0440\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
    \u043E\u0442 \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u043A\u043B\u044E\u0447-\u043A\u0430\u0440\u0442\u0430 \u043E\u0442 \u043E\u0442\u0434\u0435\u043B\u0430
    \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430\n\u041F\u043E\u043B\u0443\u0447\u0430\u0435\u043C
    \u043A\u043B\u044E\u0447 \u043E\u0442 \u0434\u0432\u0435\u0440\u0438 \"...\"
    \u0433\u0434\u0435 \u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F Grip-Claws\n\u041F\u043E\u043B\u0443\u0447\u0430\u044F
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u0433\u043B\u0430\u0432\u043D\u043E\u043C\u0443
    \u0437\u0430\u043B\u0443 \u043F\u0440\u043E\u0445\u043E\u0434\u044F \u0434\u0430\u043B\u044C\u0448\u0435
    \u043C\u044B \u0432\u0438\u0434\u0438\u043C\n\u0442\u0435\u043D\u044C \u043A\u043E\u0442\u0430.
    \u0413\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430 \xAB\u0417\u0430\u0433\u0430\u0434\u043A\u0430
    \u043F\u044C\u044F\u043D\u043E\u0433\u043E \u0441\u043B\u0435\u0441\u0441\u0430\u0440\u044F\xBB:\r\n\u0422\u044B
    \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u0448\u044C \u0432 \u043F\u0440\u043E\u0441\u0442\u043E\u0440\u043D\u044B\u0439
    \u0446\u0435\u0445 \u0441\u0431\u043E\u0440\u043A\u0438. \u0427\u0442\u043E\u0431\u044B
    \u043E\u0442\u043A\u0440\u044B\u0442\u044C \u0433\u0435\u0440\u043C\u043E\u0432\u043E\u0440\u043E\u0442\u0430
    \u0432 \xAB...\xBB, \u043D\u0443\u0436\u043D\u043E \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0446\u0435\u043F\u044C \u043F\u0438\u0442\u0430\u043D\u0438\u044F, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    Grip-Claws.\r\n\u041F\u043E\u043A\u0430 \u0442\u044B \u0442\u044F\u043D\u0435\u0448\u044C
    \u043F\u0440\u043E\u0432\u043E\u0434\u0430, \u041C\u0435\u0439\u043D \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442
    \u0438\u0433\u0440\u0430\u0442\u044C \u0441 \u0442\u043E\u0431\u043E\u0439. \u041E\u043D
    \u043D\u0435 \u043D\u0430\u043F\u0430\u0434\u0430\u0435\u0442, \u043D\u043E \u0441\u043A\u0438\u0434\u044B\u0432\u0430\u0435\u0442
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B \u0441\u0432\u0435\u0440\u0445\u0443
    \u0438\u043B\u0438 \u043F\u0440\u043E\u0431\u0435\u0433\u0430\u0435\u0442 \u043F\u043E
    \u0431\u0430\u043B\u043A\u0430\u043C \u043D\u0430\u0434 \u0433\u043E\u043B\u043E\u0432\u043E\u0439.\n\u0415\u0433\u043E
    \u0433\u043B\u0430\u0437\u0430 \u0441\u0432\u0435\u0442\u044F\u0442\u0441\u044F
    \u0436\u0435\u043B\u0442\u044B\u043C \u0432 \u0442\u0435\u043C\u043D\u043E\u0442\u0435
    \u043F\u043E\u0434 \u043F\u043E\u0442\u043E\u043B\u043A\u043E\u043C.\n\u0412\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 \u0412\u0435\u0441\u043F\u0435\u0440 (\u0424\u0438\u043D\u0430\u043B \u0433\u043B\u0430\u0432\u044B):\r\n\u0422\u044B
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0448\u044C \u0442\u044F\u0436\u0435\u043B\u0443\u044E
    \u0434\u0432\u0435\u0440\u044C \u0438 \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u0448\u044C
    \u0432 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u0447\u0438\u0441\u0442\u0443\u044E,
    \u0441\u0442\u0435\u0440\u0438\u043B\u044C\u043D\u0443\u044E \u043A\u043E\u043C\u043D\u0430\u0442\u0443
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u0440\u0430\u0437\u0440\u0443\u0445\u0438.
    \u042D\u0442\u043E \xAB...\xBB. \u0422\u0438\u0448\u0438\u043D\u0430 \u0437\u0434\u0435\u0441\u044C
    \u0440\u0435\u0436\u0435\u0442 \u0441\u043B\u0443\u0445. \u0412 \u0446\u0435\u043D\u0442\u0440\u0435
    \u043D\u0430 \u043F\u043E\u0441\u0442\u0430\u043C\u0435\u043D\u0442\u0435 \u0441\u0442\u043E\u0438\u0442
    \u0440\u043E\u0441\u043A\u043E\u0448\u043D\u0430\u044F \u043A\u043E\u0440\u043E\u0431\u043A\u0430
    \u0438\u0437 \u0442\u0435\u043C\u043D\u043E-\u0441\u0438\u043D\u0435\u0433\u043E
    \u0431\u0430\u0440\u0445\u0430\u0442\u0430.\r\n\u0422\u044B \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0448\u044C
    \u0431\u043B\u0438\u0436\u0435. \u0421\u0442\u0435\u043A\u043B\u043E \u043A\u043E\u0440\u043E\u0431\u043A\u0438
    \u0442\u0440\u0435\u0441\u043D\u0443\u0442\u043E.\r\n\u0412\u043D\u0443\u0442\u0440\u0438
    \u0441\u0438\u0434\u0438\u0442 \u043A\u0443\u043A\u043B\u0430 \u0432 \u0441\u0438\u043D\u0435\u043C
    \u043F\u043B\u0430\u0442\u044C\u0435.\r\n\u0412\u0435\u0441\u043F\u0435\u0440
    \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0435\u0442
    \u0433\u043E\u043B\u043E\u0432\u0443. \u0415\u0451 \u0433\u043B\u0430\u0437\u0430
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u0438 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u043C\u043E\u0442\u0440\u044F\u0442 \u043F\u0440\u044F\u043C\u043E \u043D\u0430
    \u0442\u0435\u0431\u044F. \u041E\u043D\u0430 \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442
    \u0442\u0443 \u0441\u0430\u043C\u0443\u044E \u0444\u0440\u0430\u0437\u0443:"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
