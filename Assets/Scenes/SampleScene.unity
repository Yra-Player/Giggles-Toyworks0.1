--- !u!102 &1344895773
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1344895771}
  m_Text: "\u041A\u043E\u043D\u0446\u0435\u043F\u0442 \u0430\u0442\u0430\u043A\u0438\n\u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0440\u043E\u0442,\n\u0447\u0442\u043E\u0431\u044B
    \u0441\u0445\u0432\u0430\u0442\u0438\u0442\u044C \u0438\u0433\u0440\u043E\u043A\u0430\n,
    \u0438\u0437-\u043F\u043E\u0434 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0440\u043E\u0437\u043E\u0432\u043E\u0433\u043E\n \u043F\u043B\u044E\u0448\u0435\u0432\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0432\u044B\u0434\u0432\u0438\u0433\u0430\u044E\u0442\u0441\u044F\n\u0441\u043A\u0440\u044B\u0442\u044B\u0435
    \u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u0437\u0430\u0445\u0432\u0430\u0442\u044B."
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
