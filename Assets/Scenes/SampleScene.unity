  m_GameObject: {fileID: 1170935433}
  m_Text: "\u0441\u0443\u0442\u044C \u043A\u0432\u0435\u0441\u0442 \u0440\u0443\u043C\u0430\n\u041F\u0440\u043E\u0442\u044F\u043D\u0443\u0442\u044C
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E\n\u0438\u0437
    \u0442\u043E\u0447\u043A\u0438 \u0410 \u0432 \u0442\u043E\u0447\u043A\u0443 \u0411\n\u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0430\u044F
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E \u0441\u0442\u043E\u043B\u0431\u044B"
