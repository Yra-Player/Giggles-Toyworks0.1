--- !u!102 &1170968114
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1170968112}
  m_Text: "\u0414\u0435\u043C\u043E \u0432\u0435\u0440\u0441\u0438\u044F \u0441\u044E\u0436\u0435\u0442\u0430\n\u0413\u043B\u0430\u0432\u0430
    1:  \"\u0422\u0438\u0445\u0438\u0439 \u0448\u0451\u043F\u043E\u0442\"\n\u0422\u044B
    \u0431\u044B\u0432\u0448\u0438\u0439 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A
    \u043E\u0442\u0434\u0435\u043B\u0430 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438\n\u041F\u043E\u043B\u0443\u0447\u0430\u0435\u0448\u044C
    \u2014 \u0441\u0442\u0430\u0440\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
    \u043E\u0442 \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u043A\u043B\u044E\u0447-\u043A\u0430\u0440\u0442\u0430 \u043E\u0442 \u043E\u0442\u0434\u0435\u043B\u0430
    \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430\n\u041F\u043E\u043B\u0443\u0447\u0430\u0435\u043C
    \u043A\u043B\u044E\u0447 \u043E\u0442 \u0434\u0432\u0435\u0440\u0438 \"...\"
    \u0433\u0434\u0435 \u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F Grip-Claws\n\u041F\u043E\u043B\u0443\u0447\u0430\u044F
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u0433\u043B\u0430\u0432\u043D\u043E\u043C\u0443
    \u0437\u0430\u043B\u0443 \u043F\u0440\u043E\u0445\u043E\u0434\u044F \u0434\u0430\u043B\u044C\u0448\u0435
    \u043C\u044B \u0432\u0438\u0434\u0438\u043C\n\u0442\u0435\u043D\u044C \u043A\u043E\u0442\u0430
    (\u043A\u043E\u043D\u0435\u0446 \u0434\u0435\u043C\u043A\u0438)"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
